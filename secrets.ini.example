; Copy this file to secrets.ini and fill in your values.
; secrets.ini is gitignored — never commit it.
;
; MQTT broker: install the "Mosquitto broker" add-on in HA,
; then use mqtt://homeassistant.local:1883 (or the HA IP).
; If you set a username/password in Mosquitto, use:
;   mqtt://user:password@homeassistant.local:1883

[env:esp32-c3-devkitm-1]
build_flags =
    -DUSE_HA_MQTT=0
;    -DUSE_HA_MQTT=1
;    '-DWIFI_SSID="your_network_name"'
;    '-DWIFI_PASSWORD="your_password"'
;    '-DMQTT_BROKER_URL="mqtt://homeassistant.local:1883"'
